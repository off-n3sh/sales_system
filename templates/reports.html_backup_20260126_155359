{% extends "bases.html" %}
{% block title %}Financial Analytics Dashboard{% endblock %}

{% block content %}
<div class="container mx-auto px-4 py-8 max-w-7xl">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 space-y-4 md:space-y-0">
        <div>
            <h2 class="text-3xl font-bold text-gray-900 dark:text-white tracking-tight">Financial Dashboard</h2>
            <div class="flex items-center gap-2 mt-1">
                <span class="flex h-2 w-2 rounded-full bg-green-500"></span>
                <p class="text-gray-500 dark:text-gray-400 text-sm">Real-time financial tracking active</p>
            </div>
        </div>
        
        <div class="flex items-center space-x-3 w-full md:w-auto">
            <select id="time-filter" 
                class="bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-700 text-gray-700 dark:text-gray-200 rounded-lg px-4 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none transition-all cursor-pointer" 
                onchange="updateFilter()">
                <option value="day" {% if time_filter == 'day' %}selected{% endif %}>📅 Today</option>
                <option value="week" {% if time_filter == 'week' %}selected{% endif %}>🗓️ This Week</option>
                <option value="month" {% if time_filter == 'month' %}selected{% endif %}>📊 This Month</option>
                <option value="year" {% if time_filter == 'year' %}selected{% endif %}>📈 This Year</option>
            </select>

            <div class="relative inline-block text-left">
                <button id="export-dropdown-btn" class="flex items-center bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded-lg font-medium text-sm transition-all shadow-sm">
                    <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                    Export
                </button>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
        <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700">
            <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest">Total Revenue</h3>
            <div class="mt-2">
                <p class="text-2xl font-black text-gray-900 dark:text-white">
                    KES {{ (chart_data.sales_vs_debts.data[0] + chart_data.sales_vs_debts.data[1]) | round(0) }}
                </p>
                <div class="flex items-center gap-2 mt-2">
                    <span class="text-[10px] px-2 py-0.5 bg-blue-50 text-blue-600 rounded">Retail: {{ chart_data.sales_vs_debts.data[0] | round(0) }}</span>
                    <span class="text-[10px] px-2 py-0.5 bg-purple-50 text-purple-600 rounded">Wholesale: {{ chart_data.sales_vs_debts.data[1] | round(0) }}</span>
                </div>
            </div>
        </div>

        <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 border-t-4 border-t-red-500">
            <h3 class="text-xs font-bold text-red-500 uppercase tracking-widest">Outstanding Debt</h3>
            <div class="mt-2">
                <p class="text-2xl font-black text-red-600">KES {{ total_debt | round(0) }}</p>
                <p class="text-xs text-gray-400 mt-1">Pending collections</p>
            </div>
        </div>

        <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 border-t-4 border-t-green-500">
            <h3 class="text-xs font-bold text-green-500 uppercase tracking-widest">Bank Liquidity</h3>
            <div class="mt-2">
                <p class="text-2xl font-black text-green-600">KES {{ (chart_data.money_in_bank.data[0] + chart_data.money_in_bank.data[1]) | round(0) }}</p>
                <p class="text-xs text-gray-400 mt-1">Cash on hand</p>
            </div>
        </div>

        <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700">
            <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest">Efficiency</h3>
            <div class="mt-2">
                {% set total_p = chart_data.paid_vs_debt.data[0] + chart_data.paid_vs_debt.data[1] %}
                {% set total_d = chart_data.paid_vs_debt.data[2] + chart_data.paid_vs_debt.data[3] %}
                {% set ratio = (total_p / (total_p + total_d) * 100) if (total_p + total_d) > 0 else 0 %}
                <div class="flex justify-between items-end">
                    <p class="text-2xl font-black text-blue-600">{{ ratio | round(1) }}%</p>
                    <span class="text-[10px] text-gray-400 mb-1 font-bold">COLLECTION RATE</span>
                </div>
                <div class="w-full bg-gray-100 dark:bg-gray-700 rounded-full h-1.5 mt-2">
                    <div class="bg-blue-600 h-1.5 rounded-full transition-all duration-1000" style="width: {{ ratio }}%"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-10">
        <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700">
            <h3 class="text-sm font-bold text-gray-700 dark:text-gray-300 mb-6 uppercase tracking-wider">Revenue vs Debt</h3>
            <div class="relative h-64"><canvas id="sales-vs-debts-chart"></canvas></div>
        </div>
        <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700">
            <h3 class="text-sm font-bold text-gray-700 dark:text-gray-300 mb-6 uppercase tracking-wider">Payment Status</h3>
            <div class="relative h-64"><canvas id="paid-vs-debt-chart"></canvas></div>
        </div>
        <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700">
            <h3 class="text-sm font-bold text-gray-700 dark:text-gray-300 mb-6 uppercase tracking-wider">Accumulated Flow</h3>
            <div class="relative h-64"><canvas id="money-in-bank-chart"></canvas></div>
        </div>
    </div>

    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg border border-gray-100 dark:border-gray-700 overflow-hidden">
        <div class="sticky top-0 z-10 bg-white dark:bg-gray-800 px-6 py-4 border-b border-gray-100 dark:border-gray-700 flex flex-col md:flex-row justify-between items-center gap-4">
            <div class="flex flex-wrap gap-1 p-1 bg-gray-50 dark:bg-gray-900 rounded-xl">
                <button class="tab-btn active px-4 py-2 text-xs font-bold rounded-lg transition-all" data-tab="orders">History</button>
                <button class="tab-btn px-4 py-2 text-xs font-bold text-gray-500 rounded-lg transition-all" data-tab="stock">Inventory</button>
                <button class="tab-btn px-4 py-2 text-xs font-bold text-gray-500 rounded-lg transition-all" data-tab="expenses">Expenses</button>
                <button class="tab-btn px-4 py-2 text-xs font-bold text-gray-500 rounded-lg transition-all" data-tab="user-actions">Audit</button>
            </div>
            
            <div class="relative w-full md:w-64">
                <input type="text" id="log-search" placeholder="Filter current tab..." 
                    class="w-full text-xs bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg pl-9 pr-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none">
                <svg class="w-4 h-4 absolute left-3 top-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            </div>
        </div>

        <div id="logs-content" class="max-h-[600px] overflow-y-auto px-6 py-2 custom-scrollbar">
            <div id="active-feed" class="divide-y divide-gray-50 dark:divide-gray-700">
                {% for order in orders %}
                <div class="py-4 flex justify-between items-center hover:bg-gray-50 dark:hover:bg-gray-700/30 px-2 rounded-xl transition-colors">
                    <div class="flex items-center space-x-4">
                        <div class="p-3 bg-blue-50 dark:bg-blue-900/20 rounded-xl">
                            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 11-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
                        </div>
                        <div>
                            <div class="flex items-center gap-2">
                                <p class="font-bold text-gray-800 dark:text-gray-200">{{ order.receipt_id }}</p>
                                <span class="text-[10px] px-1.5 py-0.5 bg-gray-100 dark:bg-gray-700 text-gray-500 rounded font-mono uppercase">{{ order.order_type }}</span>
                            </div>
                            <p class="text-xs text-gray-500">{{ order.date.strftime('%b %d, %H:%M') }} • {{ order.shop_name }}</p>
                        </div>
                    </div>
                    <div class="text-right">
                        <p class="font-bold text-gray-900 dark:text-white">KES {{ (order.total_amount) | round(0) }}</p>
                        <span class="text-[10px] font-bold uppercase {{ 'text-green-500' if order.balance == 0 else 'text-red-500' }}">
                            {{ 'Fully Paid' if order.balance == 0 else 'Bal: ' ~ order.balance }}
                        </span>
                    </div>
                </div>
                {% endfor %}
            </div>
            
            <div id="load-more-container" class="py-8 text-center">
                <button id="load-more-btn" class="text-xs font-bold text-blue-600 hover:text-blue-800 uppercase tracking-widest transition-all">
                    Load More Entries
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .tab-btn.active { @apply bg-white dark:bg-gray-800 text-blue-600 shadow-sm border border-gray-100 dark:border-gray-700; }
    .custom-scrollbar::-webkit-scrollbar { width: 5px; }
    .custom-scrollbar::-webkit-scrollbar-track { @apply bg-transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { @apply bg-gray-200 dark:bg-gray-700 rounded-full; }
</style>
{% endblock %}

{% block scripts %}
<script>
    window.chartData = {{ chart_data | tojson | safe }};
</script>
<script src="{{ url_for('static', filename='js/reports.js') }}"></script>
{% endblock %}